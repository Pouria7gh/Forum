@using Forum.Web.Areas.Admin.Models.ForumRoom
@model CreateForumRoomViewModel
<div class="container">
<form
    id="form"
    method="post" href="/Admin/ForumRoom/CreateForumRoom"
    class="mt-3"
>
    <div class="card">
        <div class="card-header p-4 mb-3 col-12 rounded-top-1 d-flex justify-content-end align-items-center">
            <h4 class="me-auto">Create new Forum room</h4>
            <button name="save-continue" class="btn btn-outline-success me-2">Save and Continue</button>
            <button name="save" class="btn btn-success" >Save</button>
        </div>
        <div class="card-body row">
            <div class="col-12 col-md-6 mb-2">
                <label asp-for="Title" class="form-label">Title:</label>
                <input asp-for="Title" class="form-control"/>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-12 col-md-6 mb-2">
                <label asp-for="Subtitle" class="form-label">Subtitle:</label>
                <input asp-for="Subtitle" class="form-control" />
                <span asp-validation-for="Subtitle" class="text-danger"></span>
            </div>
            <div class="col-12 mb-2">
                <label asp-for="Description" class="form-label">Description:</label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-12 mb-2">
                <label asp-for="Rules" class="form-label">Rules:</label>
                <textarea asp-for="Rules" class="form-control"></textarea>
                <span asp-validation-for="Rules" class="text-danger"></span>
            </div>
            <div class="col-6 mb-2">
                <label asp-for="IsClosed" class="form-check-label me-2">Is Closed:</label>
                <input asp-for="IsClosed" type="checkbox" class="form-check-input"/>
            </div>
            <div class="col-6 mb-2">
                <label asp-for="IsPinned" class="form-check-label me-2">Is Pinned:</label>
                <input asp-for="IsPinned" type="checkbox" class="form-check-input"/>
            </div>
        </div>
    </div>


    <span>
        @ViewData["Error"]
    </span>
</form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}