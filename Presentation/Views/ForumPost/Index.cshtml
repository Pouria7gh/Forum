@using Application.DTOs.ForumRoom
@using Forum.Web.Models.ForumPost
@model ForumPostDto

<div class="container p-0 mb-3 forum-room-container">
    <a class="btn btn-sm mt-3 btn-secondary" href="/ForumRoom/@Model.ForumRoomId">Back to Room</a>
    <div class="bg-body-secondary rounded mt-3 mb-3 p-3">
        <div class="d-flex justify-content-between align-items-center">
            <p class="fw-bold">
                @Model.UserDisplayName
            </p>
            <p class="text-secondary opacity-75">
                @Model.CreatedAt.ToString("g")
            </p>
        </div>
        <p style="white-space: pre-wrap">@Model.PostContent</p>
        <p>
            @Model.Description
        </p>
        <div class="mt-2 d-flex align-items-center">
            <div class="me-3">
                @Model.ViewCount <i class="bi-eye"></i>
            </div>
            <div class="me-auto">
                @Model.ReplyCount <i class="bi-chat"></i>
            </div>
            <div class="me-2">
                <button 
                    class="btn-like-post btn btn-sm btn-light @(Model.IsLiked ? "active-interaction" : "")"
                    data-forum-post-id="@Model.Id"
                >
                    @if (Model.IsLiked)
                    {
                        <i class="bi-hand-thumbs-up-fill"></i>
                    }
                    else
                    {
                        <i class="bi-hand-thumbs-up"></i> 
                    }
                </button>
                <span class="interaction-count">@Model.LikeCount</span>
            </div>
            <div class="me-1">
                <button
                    class="btn-dislike-post btn btn-sm btn-light @(Model.IsDisliked ? "active-interaction" : "")"
                    data-forum-post-id="@Model.Id"
                >
                    @if (Model.IsDisliked)
                    {
                        <i class="bi-hand-thumbs-down-fill"></i>
                    }
                    else
                    {
                        <i class="bi-hand-thumbs-down"></i>
                    }
                </button>
                <span class="interaction-count">@Model.DislikeCount</span>
            </div>
        </div>
    </div>
    
    @await Component.InvokeAsync("ListPostReplies", new { parentPostId = Model.Id })

</div>

<div class="my-2">
<partial name="_ForumPostForm" model="new AddForumPostViewModel() {ForumRoomId = Model.ForumRoomId, ParentPostId = Model.Id}" />
</div>