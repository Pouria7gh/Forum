@using Presentation.Constraints
@{
    bool userAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    string returnUrl = Context.Request.Path;
}
<!DOCTYPE html>
<html id="html" lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forum</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light border-bottom box-shadow">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Forum</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item me-auto">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @if (!userAuthenticated)
                        {
                            <a class="btn btn-sm btn-primary me-1 d-none d-sm-inline-block"
                                asp-route-returnUrl="@Context.Request.Path" 
                                asp-controller="Account" 
                                asp-action="Login"
                            >
                                Login
                            </a>
                            <a 
                                class="btn btn-sm btn-outline-primary d-none d-sm-inline-block"
                                asp-controller="Account"
                                asp-action="SignUp"
                                asp-route-returnUrl="@Context.Request.Path"
                            >
                                SignUp
                            </a>
                            <li class="nav-item me-auto d-sm-none">
                                <a class="nav-link"
                                   asp-route-returnUrl="@Context.Request.Path"
                                   asp-controller="Account"
                                   asp-action="Login">
                                    Login
                                </a>
                            </li>
                            <li class="nav-item me-auto d-sm-none">
                                <a class="nav-link"
                                   asp-controller="Account"
                                   asp-action="SignUp"
                                   asp-route-returnUrl="@Context.Request.Path">
                                    SignUp
                                </a>
                            </li>
                        }
                        
                        @if (userAuthenticated && User.IsInRole(RoleNames.ADMIN))
                        {
                            <a class="btn btn-sm btn-primary me-1 d-none d-sm-inline-block"
                                href="/Admin">
                                Dashboard
                            </a>
                            <li class="nav-item me-auto d-sm-none">
                                <a class="nav-link"
                                    href="/Admin">
                                    Dashboard
                                </a>
                            </li>

                        }

                        @if (userAuthenticated)
                        {
                            <a
                                asp-controller="Account"
                                asp-action="Logout"
                                asp-route-returnUrl="@returnUrl"
                               class="btn btn-sm btn-primary d-none d-sm-inline-block d-none d-sm-inline-block">
                                Logout
                            </a>
                            <li class="nav-item me-auto d-sm-none">
                                <a asp-controller="Account"
                                   asp-action="Logout"
                                   asp-route-returnUrl="@returnUrl"
                                   class="nav-link">
                                    Logout
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div>
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <footer class="border-top footer text-muted py-3">
        <div class="container">
            &copy; 2026 - Forum
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <partial name="_AppToast" />
    @await Html.PartialAsync("_ValidationScriptsPartial")
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>