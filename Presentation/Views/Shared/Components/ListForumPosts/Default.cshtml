@using Application.DTOs.ForumRoom
@model List<ForumPostDto>

<div class="forum-posts-container">
    @foreach(var post in Model)
    {
        <div class="border border-opacity-25 border-dark shadow-lg rounded-2 p-3 mb-2">
            @if(!string.IsNullOrEmpty(post.ParentUserDisplayName) && !string.IsNullOrEmpty(post.ParentPostContent))
            {
                <div class="alert alert-info">
                    <p>Reply to: @post.ParentUserDisplayName</p>
                    <p>@(post.ParentPostContent.Length > 30 ? post.ParentPostContent.Substring(0, 25) + "..." : post.ParentPostContent)</p>
                </div>
            }
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold">
                    @post.UserDisplayName
                </div>
                <div class="opacity-50">@post.CreatedAt.ToString("g")</div>
            </div>
            <div class="mb-1" style="white-space: pre-wrap">@post.PostContent</div>
            @if (!string.IsNullOrEmpty(post.Description))
            {
                <div class="bg-body-secondary p-2">
                    @post.Description
                </div>
            }
            <div class="mt-2 text-end">
                <button
                    data-parent-post-id="@post.Id"
                    data-user-display-name="@post.UserDisplayName"
                    data-short-post-content="@(post.PostContent.Length > 15 ? post.PostContent.Substring(0, 10) + "..." : post.PostContent)"
                    onclick="prepareFormToReply(this)"
                    class="btn btn-primary"
                >
                    Reply
                </button>
            </div>
        </div>
    }
</div>