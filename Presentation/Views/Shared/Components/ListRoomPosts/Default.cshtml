@using Application.Core
@using Application.DTOs.ForumRoom
@model PagedList<ForumPostDto>

<div class="forum-posts-container">
    @Html.AntiForgeryToken()
    @foreach(var post in Model)
    {
        <div class="border border-opacity-25 border-dark shadow-lg rounded-2 p-3 mb-2">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold">
                    @post.UserDisplayName
                </div>
                <div class="opacity-50">@post.CreatedAt.ToString("g")</div>
            </div>
            <div class="mb-1" style="white-space: pre-wrap">@post.PostContent</div>
            @if (!string.IsNullOrEmpty(post.Description))
            {
                <div class="bg-body-secondary p-2">
                    @post.Description
                </div>
            }
            <div class="mt-2 d-flex align-items-center">
                <div class="me-3">
                    @post.ViewCount <i class="bi-eye"></i>
                </div>
                <div class="me-auto">
                    @post.ReplyCount <i class="bi-chat"></i>
                </div>
                <div class="me-2">
                    <button 
                        class="btn-like-post btn btn-sm btn-light @(post.IsLiked ? "active-interaction" : "")"
                        data-forum-post-id="@post.Id"
                    >
                        @if (post.IsLiked)
                        {
                            <i class="bi-hand-thumbs-up-fill"></i>
                        }
                        else
                        {
                            <i class="bi-hand-thumbs-up"></i> 
                        }
                    </button>
                    <span class="interaction-count">@post.LikeCount</span>
                </div>
                <div class="me-3">
                    <button
                        class="btn-dislike-post btn btn-sm btn-light @(post.IsDisliked ? "active-interaction" : "")"
                        data-forum-post-id="@post.Id"
                    >
                        @if (post.IsDisliked)
                        {
                            <i class="bi-hand-thumbs-down-fill"></i>
                        }
                        else
                        {
                            <i class="bi-hand-thumbs-down"></i>
                        }
                    </button>
                    <span class="interaction-count">@post.DislikeCount</span>
                </div>
                <a href="/ForumPost/@post.Id" class="btn btn-primary">View</a>
            </div>
        </div>
    }
</div>

<partial name="_Pagination"/>